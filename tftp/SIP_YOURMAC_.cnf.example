; Rename this file to SIP + your phone's MAC address + .cnf
; Example: SIP001D45ABCDEF.cnf
; MAC address is printed on the label on the underside of the phone.
;
; Settings in this file override SIPDefault.cnf.
; You only need to include settings that differ per phone.
; The shared settings below are included for reference.

; =====================
; Firmware
; =====================
image_version: P0S3-8-12-00

; =====================
; SIP / Proxy
; =====================
; proxy1_address / proxy2_address are global fallbacks. When every line has
; its own proxy configured via line1_proxy1_address / line2_proxy1_address
; (etc.), these global fields are not needed and can cause confusion.
; Uncomment only if you are NOT using per-line proxy settings.
; proxy1_address: your-sip-provider.example.com
; With per-line proxies, proxy_register is unnecessary and may trigger
; unexpected registration behaviour. Leave commented unless you rely solely
; on a global proxy rather than per-line proxy fields.
; proxy_register: 1
; nat_enable controls whether the phone advertises its public IP in SIP
; Contact and Via headers instead of its LAN IP.
; Set to 0 (default) for LAN use — line 1 (Asterisk) always needs this.
; Set to 1 only if SIPcord (line 2) fails to register or receive calls
; from behind NAT, and also set nat_address to your public hostname/IP.
nat_enable: 0
; nat_address: your-duckdns-address.duckdns.org
register_expires: 3600
; proxy1_port: 5060
; proxy2_address: your-backup-proxy.example.com
; proxy2_port: 5060
; outbound_proxy: your-outbound-proxy.example.com
; outbound_proxy_port: 5060
; nat_received_processing: 0
; sip_port: 5060
; start_media_port: 16384
; end_media_port: 32766

; =====================
; Time & Clock (UK)
; =====================
sntp_server: pool.ntp.org
sntp_mode: unicast
time_zone: GMT
time_format_24hr: 1
date_format: D/M/Y
dst_offset: 1
dst_start_month: March
dst_start_day_of_week: Sun
dst_start_week_of_month: 8
dst_start_time: 01
dst_stop_month: Oct
dst_stop_day_of_week: Sun
dst_stop_week_of_month: 8
dst_stop_time: 02
dst_auto_adjust: 1

; =====================
; Directory & Logo
; =====================
services_url: http://YOUR_SERVER_IP:70/services.xml
directory_url: http://YOUR_SERVER_IP:70/directory.xml
logo_url: http://YOUR_SERVER_IP:70/logo.bmp
; messages_uri: sip:voicemail@YOUR_SERVER_IP
; call_logging_uri: http://YOUR_SERVER_IP:70/calllog.xml
; idle_url: http://YOUR_SERVER_IP:70/idle.xml
; idle_url_time: 5                        ; seconds before idle URL is fetched

; =====================
; Dialplan
; =====================
dial_template: dialplan

; =====================
; Call Features
; =====================
call_waiting: 1
call_hold_ringback: 1
dnd_control: 1
transfer_on_hangup: 0
; anon_call_block: 0
; callerid_blocking: 0
; remote_party_id: 0

; =====================
; Audio
; =====================
preferred_codec: g711ulaw
; Use RTP events (AVT/RFC 2833) for DTMF only.
; dtmf_inband must be 0 — leaving it 1 while dtmf_outofband is also set
; causes the phone to send DTMF twice (in-band audio + RTP events), which
; breaks IVR and voicemail on the remote end.
dtmf_inband: 0
dtmf_outofband: avt
; silence_suppression: 0

; =====================
; Line 1 — Calico internal (Asterisk)
; =====================
; Line 1 registers to the local Asterisk container.
; Set ASTERISK_LINE1_SECRET in .env and replace CHANGEME_LINE1_PASSWORD
; below with the same value.
line1_name: 2001
line1_authname: oak-line1
line1_password: CHANGEME_LINE1_PASSWORD
line1_displayname: Calico
line1_proxy1_address: YOUR_SERVER_IP
line1_proxy1_port: 5062
; line1_shortname: L1
; line1_ring_setting: 1

; =====================
; Line 2 — SIPcord (external)
; =====================
line2_name: 1001
line2_authname: CHANGEME_LINE2_AUTHNAME
line2_password: CHANGEME_LINE2_PASSWORD
line2_displayname: SIPcord
; Set line2_proxy1_address to the SIP proxy for this line (e.g. your external
; SIP provider). Using a per-line proxy here is preferred over a global
; proxy1_address so that each line can reach a different server.
line2_proxy1_address: your-sip-provider.example.com
line2_proxy1_port: 5060
; line2_shortname: L2
; line2_ring_setting: 1

; =====================
; Lines 3–6 (Cisco 7960G only)
; =====================
; line3_name:
; line3_authname:
; line3_password:
; line3_displayname:
; line3_proxy1_address:
; line3_proxy1_port: 5060
; line3_shortname:
; line3_ring_setting: 1
;
; line4_name:
; line4_authname:
; line4_password:
; line4_displayname:
; line4_proxy1_address:
; line4_proxy1_port: 5060
; line4_shortname:
; line4_ring_setting: 1
;
; line5_name:
; line5_authname:
; line5_password:
; line5_displayname:
; line5_proxy1_address:
; line5_proxy1_port: 5060
; line5_shortname:
; line5_ring_setting: 1
;
; line6_name:
; line6_authname:
; line6_password:
; line6_displayname:
; line6_proxy1_address:
; line6_proxy1_port: 5060
; line6_shortname:
; line6_ring_setting: 1

; =====================
; Display
; =====================
; contrast: 69                            ; 0–100
; user_localize: English_United_States

; =====================
; Phone Label
; =====================
phone_label: YourLabel
idle_display_text: SIPCord

; =====================
; Logging
; =====================
; log_server: your-syslog-server.example.com
