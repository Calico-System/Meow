# Secrets — never commit
.env

# Personal phone config — use the .example versions as templates
SIPDefault.cnf
SIP_*.cnf
SIP*.cnf
http/directory.xml

# Cisco firmware — do not redistribute publicly
*.sb2
*.tar
*.bin
*.sbn
*.loads

# Generated at runtime by fetch.py
http/idle.xml
http/infoservices.xml
http/services.xml
http/.speedtest_cache.json

# Generated at runtime by fetch.py — contain secrets, do not commit
asterisk/sip.conf
asterisk/pjsip.conf
asterisk/extensions.conf
asterisk/rtp.conf
asterisk/manager.conf
asterisk\manager.conf
# Readiness marker written by fetch.py after config generation completes
asterisk/.configs_written
# All other Asterisk configs are regenerated by fetch.py on every start
asterisk/*.conf

# Python
__pycache__/
*.pyc

# Windows thumbnail cache
Thumbs.db

# Personal docs
*.docx
