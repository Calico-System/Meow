# =====================
# Network
# =====================
# IP of the machine running the Docker containers
TRUENAS_IP=192.168.x.x
MINECRAFT_IP=192.168.x.x
MINECRAFT_PORT=9136
SERVER_IP=192.168.x.x
HTTP_PORT=70

# =====================
# External access
# =====================
# Your DuckDNS (or other dynamic DNS) address — used to ping external connectivity on page 7
# Leave blank to skip the external ping
DUCKDNS_ADDRESS=your-address.duckdns.org

# =====================
# Phone
# =====================
# IP of your Cisco 7940G on the LAN
PHONE_IP=192.168.x.x
PHONE_SIP_PORT=5060
# SIP extension number registered on line 1 of your phone (used for MWI LED NOTIFY)
PHONE_SIP_EXTENSION=1001

# =====================
# Location
# =====================
# Used for weather (open-meteo.com) — decimal degrees
LATITUDE=51.0000
LONGITUDE=0.0000
TIMEZONE=Europe/London
LOCATION_NAME=My Town

# =====================
# Discord
# =====================
# Create a bot at discord.com/developers and invite it to your server
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_server_id_here
# Right-click a user in Discord -> Copy User ID (enable Developer Mode first)
OWNER_USER_ID=your_discord_user_id_here
# DMs from this user go to page 12 and override all other pages for 5 minutes
# Set to the same as OWNER_USER_ID if you don't need a separate priority user
PRIORITY_USER_ID=priority_user_discord_id_here
# Display name for the priority user — shown in bot messages
PRIORITY_USER_NAME=the priority user

# =====================
# TrueNAS (optional)
# =====================
# API key from TrueNAS UI -> Credentials -> API Keys
# Leave blank to disable TrueNAS pool display on page 9
TRUENAS_KEY=your_truenas_api_key_here

# =====================
# Customisation
# =====================
# How long each page stays on screen before advancing (seconds)
IDLE_CYCLE_SECONDS=30
# How often to run a speedtest (seconds — 3600 = 1 hour)
SPEEDTEST_INTERVAL=3600
# Light the phone's red MWI LED when a DM arrives (true/false)
MWI_ENABLED=true
# How long to keep the MWI LED lit after a DM (seconds, should match DM page timeout)
MWI_DM_DURATION=300
# Minimum time between DMs from non-priority users (seconds)
DM_COOLDOWN_SECONDS=60
# Name shown for your Minecraft server on page 9
MINECRAFT_SERVER_NAME=My Server
# Base currency for exchange rates on page 3 (e.g. GBP, USD, EUR)
NEWS_BASE_CURRENCY=GBP

# =====================
# Ping hosts (up to 5)
# =====================
# Add as many as you need up to PING_HOST_5_*
PING_HOST_1_NAME=Google
PING_HOST_1_IP=8.8.8.8
PING_HOST_2_NAME=Router
PING_HOST_2_IP=192.168.x.x
PING_HOST_3_NAME=SIPcord
PING_HOST_3_IP=bridge-eu1.sipcord.net
